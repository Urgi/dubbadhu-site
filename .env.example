# Copy to `.env` for local dev. Vite only exposes variables prefixed with VITE_.
#
# Use the SAME Supabase project as the Dubbadhu app:
#   VITE_SUPABASE_URL      = same value as SUPABASE_URL in the app (.env / EAS)
#   VITE_SUPABASE_ANON_KEY = same value as SUPABASE_ANON_KEY (the public anon key is OK in the browser)
#
# Signups call RPC `check_and_join_waitlist` → table `waitlist_signups` (same as onboarding / Profile language waitlist).
#
# Production / static hosting: set these in your CI or host "build environment" before `npm run build`.
# Vite inlines them at build time; setting vars only on the server after build will NOT connect the waitlist.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: value stored in waitlist_signups.language for the main site "Notify Me" form (default: Afaan Oromo).
# Must match whatever you use in reports / the RPC has no allowlist — any non-empty string is stored.
# VITE_WAITLIST_IOS_LANGUAGE=Afaan Oromo
